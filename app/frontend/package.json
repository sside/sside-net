{
    "name": "@sside-net/frontend",
    "version": "0.0.0",
    "private": true,
    "description": "sside.net frontend",
    "scripts": {
        "start": "next start",
        "dev": "rimraf .next & dotenvx run --env-file ../../.env -- cross-env PORT=42979 next dev --turbopack",
        "build": "next build",
        "test:cli": "playwright test",
        "test:ui": "playwright test --ui",
        "test:ts": "tsc --noEmit",
        "lint": "eslint --fix",
        "update:check": "ncu",
        "update:execute": "ncu -u"
    },
    "dependencies": {
        "@sentry/nextjs": "10.27.0",
        "@sside-net/date-time": "*",
        "cross-env": "10.1.0",
        "dedent": "^1.7.1",
        "http-status-codes": "2.3.0",
        "luxon": "^3.7.2",
        "next": "16.1.6",
        "openapi-fetch": "0.17.0",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-markdown": "^10.1.0",
        "rehype-raw": "^7.0.0",
        "remark-gfm": "^4.0.1",
        "tailwind-merge": "^3.5.0",
        "tailwind-variants": "^3.2.2"
    },
    "devDependencies": {
        "@dotenvx/dotenvx": "1.52.0",
        "@faker-js/faker": "9.9.0",
        "@next/eslint-plugin-next": "16.1.6",
        "@playwright/test": "1.58.2",
        "@sside-net/eslint": "*",
        "@sside-net/open-api": "*",
        "@tailwindcss/postcss": "4.1.18",
        "@types/luxon": "^3.7.1",
        "@types/node": "22",
        "@types/react": "19",
        "@types/react-dom": "19",
        "msw": "2.12.10",
        "postcss": "8.5.6",
        "rimraf": "^6.1.3",
        "tailwindcss": "4.1.18",
        "typescript": "5.9.3"
    }
}
