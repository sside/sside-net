{
    "compilerOptions": {
        "module": "commonjs",
        "lib": ["ES2023"],
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "ES2021",
        "sourceMap": true,
        "outDir": "./dist",
        "baseUrl": "./",
        "incremental": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": false,
        "strict": true,
        "strictPropertyInitialization": false
    }
}
