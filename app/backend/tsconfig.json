{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2024",
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "outDir": "./dist",
        "incremental": true,
        "skipLibCheck": true,
        "types": ["node"],
        "strict": true,
        "strictPropertyInitialization": false,
        "forceConsistentCasingInFileNames": true
    }
}
