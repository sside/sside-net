{
    "name": "@sside-net/backend",
    "version": "0.0.0",
    "description": "sside.net backend",
    "private": true,
    "scripts": {
        "start": "node dist/main",
        "dev": "dotenvx run --env-file ../../.env -- nest start --watch",
        "build": "nest build",
        "build:app": "npm run build",
        "lint": "eslint --fix",
        "test": "dotenvx run --env-file ../../.env.test -- jest",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "seed": "node ./dist/src/seed/seed.ts",
        "seed:dev": "dotenvx run --env-file ../../.env -- prisma migrate reset --force && dotenvx run --env-file ../../.env -- ts-node ./src/seed/seed.ts",
        "update:check": "ncu",
        "update:execute": "ncu -u",
        "postinstall": "dotenvx run --env-file ../../.env -- prisma generate"
    },
    "dependencies": {
        "@dotenvx/dotenvx": "1.52.0",
        "@faker-js/faker": "9.9.0",
        "@nestjs/common": "11.1.11",
        "@nestjs/core": "11.1.11",
        "@nestjs/platform-express": "11.1.11",
        "@nestjs/swagger": "11.2.6",
        "@prisma/adapter-better-sqlite3": "7.5.0",
        "@prisma/client": "7.5.0",
        "@sside-net/constant": "*",
        "@sside-net/open-api": "*",
        "@sside-net/utility": "*",
        "@sside-net/validator": "*",
        "class-transformer": "0.5.1",
        "class-validator": "0.15.1",
        "helmet": "8.1.0",
        "luxon": "3.7.2",
        "reflect-metadata": "0.2.2",
        "rxjs": "7.8.2"
    },
    "devDependencies": {
        "@nestjs/cli": "11.0.16",
        "@nestjs/schematics": "11.0.9",
        "@nestjs/testing": "11.1.11",
        "@sside-net/date-time": "*",
        "@sside-net/eslint": "*",
        "@sside-net/jest": "*",
        "@swc/cli": "0.8.0",
        "@swc/core": "1.15.8",
        "@types/express": "5.0.6",
        "@types/luxon": "3.7.1",
        "@types/node": "24",
        "@types/supertest": "7.2.0",
        "globals": "17.4.0",
        "prisma": "7.5.0",
        "source-map-support": "0.5.21",
        "supertest": "7.2.2",
        "ts-loader": "9.5.4",
        "ts-node": "10.9.2",
        "tsconfig-paths": "4.2.0",
        "typescript": "5.9.3"
    }
}
