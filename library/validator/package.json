{
    "name": "@sside-net/validator",
    "version": "0.0.0",
    "description": "sside.net shared validators",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsc --watch",
        "dev:shared": "npm run dev",
        "build": "rimraf dist && tsc --build",
        "build:shared": "npm run build",
        "lint": "eslint --fix",
        "test": "dotenvx run --env-file ../../.env.test -- jest",
        "update:check": "ncu",
        "update:execute": "ncu -u"
    },
    "dependencies": {
        "@sside-net/app-config": "*",
        "@sside-net/utility": "*"
    },
    "devDependencies": {
        "@sside-net/eslint": "*",
        "@sside-net/jest": "*",
        "@sside-net/tsconfig": "*",
        "@types/luxon": "3.7.1",
        "@faker-js/faker": "9.9.0",
        "rimraf": "6.1.3",
        "typescript": "5.9.3"
    },
    "private": true
}
