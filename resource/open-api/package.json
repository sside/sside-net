{
    "name": "@sside-net/open-api",
    "version": "0.0.0",
    "description": "sside.net OpenAPI documents",
    "main": "ts-schema/backend-schema.d.ts",
    "files": [
        "dist",
        "open-api.json"
    ],
    "private": true,
    "scripts": {
        "build": "rimraf dist && tsc --build",
        "build:shared": "npm run build",
        "generate:client": "openapi-typescript ./open-api.json --output ../../app/frontend/library/api-client/backend-schema.ts --make-paths-enum",
        "lint": "eslint --fix",
        "update:check": "ncu",
        "update:execute": "ncu -u"
    },
    "dependencies": {
        "@sside-net/project-logger": "*"
    },
    "devDependencies": {
        "@sside-net/eslint": "*",
        "@sside-net/tsconfig": "*",
        "@types/node": "24",
        "openapi-typescript": "7.13.0",
        "rimraf": "6.1.3",
        "typescript": "5.9.3"
    }
}
