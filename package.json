{
    "name": "sside-net",
    "scripts": {
        "build": "turbo run build:shared && turbo run build:app",
        "build:app": "turbo run build:app",
        "build:shared": "turbo run build:shared",
        "dev": "turbo run dev",
        "dev:shared": "npm run build:shared && turbo run dev:shared",
        "test": "turbo run test",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{js,jsx,ts,tsx,md,yml,yaml,json}\"",
        "update:check": "ncu && turbo run update:check",
        "update:execute": "ncu -u && turbo run update:execute && npm install",
        "template": "plop",
        "reinstall": "node ./deleteNodeModules.js && npm install",
        "prepare": "husky"
    },
    "devDependencies": {
        "@commitlint/cli": "20.2.0",
        "@commitlint/config-conventional": "21.2.0",
        "@inquirer/search": "4.2.1",
        "@trivago/prettier-plugin-sort-imports": "6.0.2",
        "husky": "9.1.7",
        "inquirer-autocomplete-prompt": "3.0.1",
        "lint-staged": "16.4.0",
        "npm-check-updates": "22.2.9",
        "plop": "4.0.5",
        "prettier": "3.8.3",
        "prettier-plugin-tailwindcss": "0.7.2",
        "turbo": "2.5.8"
    },
    "engines": {
        "node": ">=22"
    },
    "packageManager": "npm@11.7.0",
    "workspaces": [
        "app/*",
        "config/*",
        "library/*",
        "resource/*",
        "generated/*"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/sside/sside-net.git"
    },
    "private": true
}
